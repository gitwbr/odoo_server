                            </tbody>
                        </table>	

						<t t-set="SHOW_PRICE" t-value="doc.is_show_price or (doc.checkout_order_type == 'd' and not doc.is_sign)"/>						
						<div class="report-crm-checkout-detail">
							<div class="row" style="border-bottom: 2px solid black;  margin-bottom:10px;">
								<div class="col text-center" style="flex: 1;">項</div>
								<div class="col text-center" style="flex: 4;">製作内容</div>
								<div class="col text-center" style="flex: 1;">尺寸cm</div>
								<t t-if="0">
									<div class="col text-center" style="flex: 1;">才數</div>
								</t>
								<div class="col text-center" style="flex: 1;">數量</div>
								<t t-if="0">
									<div class="col text-center" style="flex: 1;">單價</div>
									<div class="col text-center" style="flex: 1;">其它</div>
								</t>

								<div class="col text-center" style="flex: 1;">小計</div>
							</div>	
							<t t-set="row_count" t-value="0"/>
							<t t-foreach="doc.product_ids" t-as="order">
								<!-- 本條是否有成本行（算入行數） -->
								<t t-set="has_chengben" t-value="doc.checkout_order_type == 'd' and not doc.is_sign and doc.checkout_order_state == 'waiting_confirmation' and (order.crm_chengben_comment or (order.crm_chengben or 0) != 0)"/>
								<t t-set="row_count_after" t-value="row_count + 1 + (1 if has_chengben else 0)"/>
								<!-- 换页后（累计13、29、45…行之后）先输出表头 -->
								<t t-if="row_count == 13 or ((row_count - 13) % 16 == 0 and row_count &gt; 13)">
									<div class="row" style="border-bottom: 2px solid black; margin-bottom:10px;">
										<div class="col text-center" style="flex: 1;">項</div>
										<div class="col text-center" style="flex: 4;">製作内容</div>
										<div class="col text-center" style="flex: 1;">尺寸cm</div>
										<t t-if="0">
											<div class="col text-center" style="flex: 1;">才數</div>
										</t>
										<div class="col text-center" style="flex: 1;">數量</div>
										<t t-if="0">
											<div class="col text-center" style="flex: 1;">單價</div>
											<div class="col text-center" style="flex: 1;">其它</div>
										</t>
										<div class="col text-center" style="flex: 1;">小計</div>
									</div>
								</t>
								<div class="keep-together">
								<div class="row pdf-row fixed-3" style="border-bottom:1px solid lightgray; height:78px; min-height:78px;">
									<div class="col text-center" style="flex: 1;">
										<div class="cell-3 center">
											<span t-field="order.sequence" />
										  </div>
									</div>
									
									<div class="col text-center" style="flex: 4;">
										<div class="cell-3 multi">
											<t t-set="last_value" t-value="False"/>
											<t t-set="part1" t-value="(order.project_product_name or '').replace('其他','').replace('其它','')"/>
											<t t-if="part1">
												<span t-esc="part1"/>
												<t t-set="last_value" t-value="True"/>
											</t>
											<t t-set="part2" t-value="(order.product_id.name or '').replace('其他','').replace('其它','')"/>
											<t t-if="part2">
												<t t-if="last_value">
													<t t-raw="'/'"/>
												</t>
												<span t-esc="part2"/>
												<t t-set="last_value" t-value="True"/>
											</t>
											<t t-foreach="order.product_atts" t-as="attr">
												<t t-set="part_attr" t-value="(attr.name or '').replace('其他','').replace('其它','')"/>
												<t t-if="part_attr">
													<t t-if="last_value">
														<t t-raw="'/'"/>
													</t>
													<span t-esc="part_attr"/>
													<t t-set="last_value" t-value="True"/>
												</t>
											</t>
											<t t-set="part_multi" t-value="(order.multi_chose_ids and order.multi_chose_ids or '').replace('其他','').replace('其它','')"/>
											<t t-if="part_multi">
												<t t-if="last_value">
													<t t-raw="'/'"/>
												</t>
												<span t-esc="part_multi"/>
											</t>
										</div>
									</div>
									<div class="col text-center" style="flex: 1;">
										<div class="cell-3 multi">
											<span t-field="order.product_width" />x<span t-field="order.product_height" />	
										</div>
									</div>
									
									<t t-if="0">
										<div class="col text-center" style="flex: 1;">
											<div class="cell-3 multi">
												<span t-esc="'{:,.0f}'.format((order.total_units))" />
											</div>
										</div>
									</t>
									<div class="col text-center no-wrap" style="flex: 1;">
										<div class="cell-3 multi">
											<span t-esc="'{:,.0f}'.format((order.quantity))" />
										</div>
									</div>
									
									<t t-if="0">
										<div class="col text-center" style="flex: 1;">
											<div class="cell-3 multi">
												<span t-esc="'{:,.0f}'.format((order.units_price))" />
											</div>
										</div>
										<div class="col text-center" style="flex: 1;">
											<div class="cell-3 multi">
												<span t-esc="'{:,.0f}'.format((order.total_make_price + order.peijian_price))" />
											</div>
										</div>
									</t>
									<div class="col text-center" style="flex: 1;">
										<div class="cell-3 multi">
											<span t-esc="'{:,.0f}'.format((order.price))" />
										
										</div>
									</div>
								</div>
								</div>
								<!--  and  -->
								<t t-if="doc.checkout_order_type == 'd' and not doc.is_sign ">
									<t t-if="doc.checkout_order_state == 'waiting_confirmation'">
										<t t-if="order.crm_chengben_comment or (order.crm_chengben or 0) != 0">
											<div class="keep-together">
											<div class="row pdf-row fixed-3" style="border-bottom:1px solid lightgray; height:78px; min-height:78px;">

												<div class="col text-center" style="flex: 10;">
													<div class="cell-3 multi">
